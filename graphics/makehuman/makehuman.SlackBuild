#  OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY,
#  WHETHER IN CONTRACT, STRICT LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR
#  OTHERWISE) ARISING IN ANY WAY OUT OF THE USE OF THIS SOFTWARE, EVEN IF
#  ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.

# 20220304 bkw: Modified by SlackBuilds.org: fix build on 15.0,
# by upgrading to the latest release.

cd $(dirname $0) ; CWD=$(pwd)

PRGNAM=makehuman
VERSION=${VERSION:-1.3.0}
ASSETVER=8cf9645b975a98eea056b140df11a1d278da0d10
BUILD=${BUILD:-1}
TAG=${TAG:-_SBo}
PKGTYPE=${PKGTYPE:-tgz}

ARCH=noarch

if [ ! -z "${PRINT_PACKAGE_NAME}" ]; then
  echo "$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
  exit 0
fi

TMP=${TMP:-/tmp/SBo}
PKG=$TMP/package-$PRGNAM
OUTPUT=${OUTPUT:-/tmp}

set -e

rm -rf $PKG
mkdir -p $TMP $PKG $OUTPUT
cd $TMP
rm -rf $PRGNAM-$VERSION
tar xvf $CWD/$PRGNAM-$VERSION.tar.gz
tar xvf $CWD/$PRGNAM-assets-$ASSETVER.tar.gz
cp -r $PRGNAM-assets-$ASSETVER/base/* $PRGNAM-$VERSION/$PRGNAM/data/

cd $PRGNAM-$VERSION
chown -R root:root .
patch -p1 < $CWD/makehuman-numpy2.patch
#sed -i \
#'s/np\.fromstring(pixels, dtype=np\.uint32)/np.frombuffer(pixels, dtype=np.uint32)/' \
#makehuman/lib/image_qt.py
mkdir -p .git

# enable release build and set version information
cd buildscripts
sed -e '/#isRelease = True/s/^#//' \
      -e 's/#version=.*$/version='"$VERSION/" \
      -e '/#gitBranch=master/s/^#//' \
      < build.conf.example > build.conf

# fix desktop file
sed -i -e 's/MakeHuman VERSION/MakeHuman/' \
      -e 's|Icon=/usr/share/makehuman/makehuman.svg|Icon=makehuman|' \
      deb/debian/MakeHuman.desktop

cd -
python buildscripts/build_prepare.py --nodownload . "$PKG/build"
# compile python bytecode
python -m compileall -o 0 -o 1 -s "$PKG/build" -p /opt "$PKG/build/$PRGNAM"

#cd $PKG
mkdir -p $PKG/opt/
cp -r "$PKG/build/$PRGNAM" "$PKG/opt/"

# remove empty directories
find "$PKG/opt/$PRGNAM" -empty -type d -delete

# remove exec permission from regular files except makehuman.py
find "$PKG/opt/$PRGNAM" -executable -type f -exec chmod a-x '{}' +
chmod a+x "$PKG/opt/$PRGNAM/$PRGNAM.py"

install -d "$PKG/usr/share/icons/hicolor/32x32/apps"
ln -s /opt/$PKG/icons/$PRGNAM.png "$PKG/usr/share/icons/hicolor/32x32/apps/"
install -Dm 644 -t "$PKG/usr/share/icons/hicolor/scalable/apps" "$PRGNAM/icons/$PRGNAM.svg"

install -d "$PKG/usr/bin"
ln -s /opt/$PRGNAM/$PRGNAM.py "$PKG/usr/bin/$PRGNAM"

install -Dm 644 -t "$PKG/usr/share/applications" "buildscripts/deb/debian/MakeHuman.desktop"
rm -rf $PKG/build
#mkdir -p $PKG/usr/share/applications
#cp buildscripts/deb/debian/MakeHuman.desktop $PKG/usr/share/applications/
#sed -i "s/VERSION/${VERSION}/g" $PKG/usr/share/applications/MakeHuman.desktop

mkdir -p $PKG/usr/doc/$PRGNAM-$VERSION
mv LICENSE*.md README.md $PRGNAM/licenses/* $PKG/usr/doc/$PRGNAM-$VERSION
cat $CWD/$PRGNAM.SlackBuild > $PKG/usr/doc/$PRGNAM-$VERSION/$PRGNAM.SlackBuild

mkdir -p $PKG/install
cat $CWD/slack-desc > $PKG/install/slack-desc
cat $CWD/doinst.sh > $PKG/install/doinst.sh

cd $PKG
/sbin/makepkg -l y -c n $OUTPUT/$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE
