Fix CUDA training-op build against changed core helper stream signatures.

The CUDA Plugin EP core implementation (upstream commit 879f65911a8) changed
several core CUDA provider helpers to take a raw cudaStream_t instead of an
onnxruntime::Stream*, and updated the non-training call sites accordingly, but
left the orttraining kernels passing ctx->GetComputeStream() (a Stream*):

  * SoftMaxComputeHelper now takes SoftmaxComputeStreamT (cudaStream_t);
    softmax.cc passes Stream(ctx). Match that in the loss kernels.
  * GatherNDBase::PrepareCompute now takes (void* alloc_stream,
    cudaStream_t cuda_stream, ...); gather_nd.cc passes
    (GetComputeStream(ctx), Stream(ctx), ...). Match that in gather_nd_grad.

Without this the CUDA build fails to compile the orttraining loss and
gather_nd_grad kernels.

diff --git a/orttraining/orttraining/training_ops/cuda/loss/softmax_cross_entropy_loss_impl.cc b/orttraining/orttraining/training_ops/cuda/loss/softmax_cross_entropy_loss_impl.cc
index 6b9f557e119..b3501e62b5a 100644
--- a/orttraining/orttraining/training_ops/cuda/loss/softmax_cross_entropy_loss_impl.cc
+++ b/orttraining/orttraining/training_ops/cuda/loss/softmax_cross_entropy_loss_impl.cc
@@ -110,7 +110,7 @@ Status SoftmaxCrossEntropyLoss<T, TLabel, TOut>::ComputeInternal(OpKernelContext
   }
 
   // Calculate logsoftmax
-  auto status = SoftMaxComputeHelper<T, TOut, true>(ctx->GetComputeStream(), logit_data, logit_reshape, log_prob_data, 1);
+  auto status = SoftMaxComputeHelper<T, TOut, true>(Stream(ctx), logit_data, logit_reshape, log_prob_data, 1);
   ORT_RETURN_IF_ERROR(status);
 
   const T* weight_data = nullptr;
